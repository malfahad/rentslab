# Canonical origin for this marketing site (sitemap, Open Graph). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Full URLs to frontend-app auth routes (used for header + hero CTAs).
NEXT_PUBLIC_LOGIN_URL=https://app.example.com/login
NEXT_PUBLIC_REGISTER_URL=https://app.example.com/register

# Optional: demo video, Loom, or in-app preview — powers "View demo dashboard" + header Demo link.
NEXT_PUBLIC_DEMO_URL=https://app.example.com/demo
