# Canonical origin for this app (metadata, Open Graph). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Django API origin (no trailing slash). Browser calls `${NEXT_PUBLIC_API_ORIGIN}/api/v1/...`.
# Default in code is http://127.0.0.1:8002 when unset.
NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:8002

# Optional. When set, used as the active org id before GET /api/v1/orgs/ runs (local API dev).
# NEXT_PUBLIC_DEFAULT_ORG_ID=1
